# ============================================================
# NEURITO — Configuración (copia este archivo a .env en local,
# o define estas variables en Railway → Variables)
# NUNCA subas el archivo .env real al repositorio.
# ============================================================

# ---------- Zona horaria (fija, no cambiar) ----------
TIMEZONE=America/Bogota

# ---------- Monitoreo ----------
# Sitio y resultado objetivo
TARGET_ROW=10:10 A            # fila exacta a vigilar en la tabla
MONITOR_START=21:10          # hora Colombia a la que empieza a consultar
MONITOR_END=21:30            # hora Colombia a la que se detiene si no salió
POLL_INTERVAL_SECONDS=10     # frecuencia de consulta normal
RETRY_INTERVAL_SECONDS=30    # frecuencia de reintento si el sitio está caído

# ---------- Instagram Graph API (API oficial de Meta) ----------
# La cuenta debe ser Business/Creator. NO uses tu contraseña aquí.
# El token del botón "Generar identificador" (Instagram Login) YA es de ~60 días:
# se pega tal cual, sin canje. NEURITO lo auto-refresca cada 7 días (token_manager.py).
IG_USER_ID=                  # ID numérico de la cuenta de Instagram (aquí: 17841442024763687)
IG_ACCESS_TOKEN=             # token IGAA... del panel (largo, ~60 días)
IG_GRAPH_VERSION=v21.0
# Host de la API según la ruta que elijas al configurar el producto Instagram:
#   - "API con inicio de sesión de Facebook" -> graph.facebook.com  (por defecto)
#   - "API con inicio de sesión de Instagram" -> graph.instagram.com
IG_GRAPH_HOST=graph.facebook.com
IG_MAX_PUBLISH_RETRIES=3

# ---------- URL pública del servicio (para que la API lea la imagen) ----------
# En Railway es el dominio público del servicio, p.ej. https://neurito.up.railway.app
# La Graph API necesita descargar la imagen desde una URL pública.
PUBLIC_BASE_URL=

# ---------- Plantilla e imagen de salida ----------
TEMPLATE_PATH=assets/template/plantilla.png
OUTPUT_DIR=output

# Posiciones como FRACCIÓN del tamaño de la imagen (0.0–1.0). Independientes de la
# resolución. Calíbralas con calibrador.html o con el endpoint /preview.

# Los 3 dígitos del resultado, uno por círculo (valores calibrados):
DIGIT_Y=0.398              # altura (Y) de los tres dígitos
DIGIT1_X=0.203             # X del 1er círculo
DIGIT2_X=0.502             # X del 2do círculo
DIGIT3_X=0.795             # X del 3er círculo
DIGIT_FONT_FRAC=0.098      # tamaño de fuente del dígito (fracción de la altura)
DIGIT_COLOR=#111111        # negro (como en la plantilla)
DIGIT_FONT_PATH=assets/fonts/number.ttf

# La fecha (junto al ícono de calendario):
DATE_X=0.519
DATE_Y=0.824
DATE_FONT_FRAC=0.043
DATE_COLOR=#FFFFFF
DATE_FONT_PATH=assets/fonts/date.ttf
DATE_FORMAT=%d/%m/%Y

# ---------- Alertas al administrador (opcional, vía Telegram) ----------
# Si se definen, NEURITO avisa por Telegram ante fallos críticos.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- Modo prueba ----------
# DRY_RUN=true genera la imagen pero NO publica en Instagram (para testing).
DRY_RUN=false

# Clave para habilitar el endpoint manual /test-publish (publica un día pasado).
# Vacío = endpoint DESHABILITADO (recomendado en producción). Ponle un valor secreto
# solo si quieres poder disparar publicaciones manuales: /test-publish?key=TU_CLAVE
TEST_PUBLISH_KEY=
